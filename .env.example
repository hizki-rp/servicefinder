# Example Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL Database (Render or other hosting)
# For LOCAL development: Use the EXTERNAL URL (without -a in hostname)
# For RENDER deployment: Use the INTERNAL URL (with -a in hostname)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://your_user:your_password@dpg-xxxxx.oregon-postgres.render.com/your_database

# ============================================
# DJANGO SETTINGS
# ============================================

# Debug mode (True for development, False for production)
DEBUG=True

# Secret key for Django (generate a new one for production)
SECRET_KEY=your-secret-key-here

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ============================================
# PAYMENT INTEGRATION (CHAPA)
# ============================================

CHAPA_SECRET_KEY=your-chapa-secret-key
CHAPA_WEBHOOK_SECRET=your-chapa-webhook-secret

# ============================================
# APPLICATION URLS
# ============================================

BACKEND_URL=https://your-backend.onrender.com
FRONTEND_URL=https://your-frontend.com

# ============================================
# EMAIL CONFIGURATION
# ============================================

EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-character-app-password

# ============================================
# CELERY / REDIS (Optional)
# ============================================

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# RENDER DEPLOYMENT (Optional)
# ============================================

# Set to true when deploying on Render
RENDER=false

# ============================================
# NOTES
# ============================================

# 1. Never commit the actual .env file to git
# 2. Keep .env in .gitignore
# 3. For local development, you can use SQLite by setting USE_LOCAL_DB=true
# 4. For Render PostgreSQL:
#    - Local connections: Use External URL (no -a)
#    - Render services: Use Internal URL (with -a)
# 5. Generate strong passwords for production
# 6. Update ALLOWED_HOSTS with your actual domains
